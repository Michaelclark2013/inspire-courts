# ─── Required ─────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-key-here
ADMIN_EMAIL=your-admin-email@example.com

# ─── Database (Turso/libsql) ──────────────────────────────
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Auth ─────────────────────────────────────────────────
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here
NEXTAUTH_URL=https://inspirecourtsaz.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Google Sheets / Drive ────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Square Payments (optional) ───────────────────────────
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# ─── Notion (optional) ───────────────────────────────────
NOTION_API_KEY=secret_xxxxx
CHAT_LEADS_DB_ID=your-notion-database-id

# ─── AI Chat (optional — enables Claude-powered assistant)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Email (optional — enables lead notification emails) ──
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ─── Mailchimp (optional — enables newsletter subscribe) ──
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_LIST_ID=your-mailchimp-list-id

# ─── Analytics (optional) ─────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# ─── Push Notifications (optional) ────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:info@inspirecourtsaz.com
